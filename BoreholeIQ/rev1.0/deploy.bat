set "PY_VER=3.12.7"
set "PY_INS=%TEMP%\python-3.12.7-amd64.exe"
powershell -ExecutionPolicy Bypass -NoProfile -Command "Invoke-WebRequest -Uri 'https://www.python.org/ftp/python/3.12.7/python-3.12.7-amd64.exe' -OutFile '%PY_INS%' -UseBasicParsing" >nul 2>&1
